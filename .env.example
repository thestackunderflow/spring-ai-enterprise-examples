# Copy to `.env` and fill in ‚Äî `.env` is git-ignored. Never commit real keys.
# Load however you prefer (direnv, an IDE run-config, or `export $(grep -v '^#' .env | xargs)`).

# Required for the OpenAI-based examples (episodes 1, 3, 5, ...)
OPENAI_API_KEY=sk-your-key-here

# Optional ‚Äî used in the model-portability episode (4) and Claude examples
ANTHROPIC_API_KEY=

# Optional ‚Äî used in the RAG-with-Redis example (episode 6, production track)
# Run a local vector store first:  docker run -p 6379:6379 redis/redis-stack:latest
